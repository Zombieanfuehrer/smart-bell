  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->recv(sn, buf, len);
  }
  return SOCK_ERROR;
}

int32_t sendto(uint8_t sn, uint8_t* buf, uint16_t len, uint8_t* addr, uint16_t port) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->sendto(sn, buf, len, addr, port);
  }
  return SOCK_ERROR;
}

int32_t recvfrom(uint8_t sn, uint8_t* buf, uint16_t len, uint8_t* addr, uint16_t* port) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->recvfrom(sn, buf, len, addr, port);
  }
  return SOCK_ERROR;
}

int8_t ctlsocket(uint8_t sn, ctlsock_type cstype, void* arg) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->ctlsocket(sn, cstype, arg);
  }
  return SOCK_ERROR;
}

int8_t setsockopt(uint8_t sn, sockopt_type sotype, void* arg) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->setsockopt(sn, sotype, arg);
  }
  return SOCK_ERROR;
}

int8_t getsockopt(uint8_t sn, sockopt_type sotype, void* arg) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->getsockopt(sn, sotype, arg);
  }
  return SOCK_ERROR;
}

// W5500-Register Funktionen
uint8_t getSn_SR(uint8_t sn) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->getSn_SR(sn);
