#include "MockWiznetAPI.h"

// Globale Mock-Instanz
MockWiznetAPI* g_mock_wiznet_api = nullptr;

// C-Wrapper für Socket-API Funktionen
extern "C" {

int8_t socket(uint8_t sn, uint8_t protocol, uint16_t port, uint8_t flag) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->socket(sn, protocol, port, flag);
  }
  return SOCK_ERROR;
}

int8_t close(uint8_t sn) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->close(sn);
  }
  return SOCK_ERROR;
}

int8_t listen(uint8_t sn) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->listen(sn);
  }
  return SOCK_ERROR;
}

int8_t connect(uint8_t sn, uint8_t* addr, uint16_t port) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->connect(sn, addr, port);
  }
  return SOCK_ERROR;
}

int8_t disconnect(uint8_t sn) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->disconnect(sn);
  }
  return SOCK_ERROR;
}

int32_t send(uint8_t sn, uint8_t* buf, uint16_t len) {
  if (g_mock_wiznet_api) {
    return g_mock_wiznet_api->send(sn, buf, len);
  }
  return SOCK_ERROR;
}

